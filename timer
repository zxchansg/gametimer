<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Game Master Stopwatch</title>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        text-align: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        padding: 40px 20px;
    }

    h1 {
        color: white;
        margin-bottom: 40px;
        font-size: 2.5em;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .controls {
        display: flex;
        justify-content: center;
        gap: 15px;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .master-btn {
        padding: 12px 24px;
        font-size: 16px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: 600;
        color: white;
    }

    .master-btn.start-all {
        background: #2ecc71;
    }

    .master-btn.start-all:hover {
        background: #27ae60;
        transform: scale(1.05);
    }

    .master-btn.pause-all {
        background: #f39c12;
    }

    .master-btn.pause-all:hover {
        background: #e67e22;
        transform: scale(1.05);
    }

    .master-btn.reset-all {
        background: #e74c3c;
    }

    .master-btn.reset-all:hover {
        background: #c0392b;
        transform: scale(1.05);
    }

    .container {
        display: flex;
        justify-content: center;
        gap: 40px;
        flex-wrap: wrap;
    }

    .team {
        background: white;
        width: 320px;
        padding: 30px;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.3);
        transition: all 0.3s ease;
    }

    .team.running {
        box-shadow: 0 10px 40px rgba(46, 204, 113, 0.5);
        transform: scale(1.02);
    }

    .team h2 {
        color: #333;
        margin-bottom: 20px;
        font-size: 1.8em;
    }

    .time {
        font-size: 56px;
        font-weight: bold;
        margin: 30px 0;
        letter-spacing: 3px;
        font-family: 'Courier New', monospace;
        color: #667eea;
        min-height: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .button-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    button {
        font-size: 16px;
        padding: 12px 18px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .start {
        background: #2ecc71;
        color: white;
    }

    .start:hover:not(:disabled) {
        background: #27ae60;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(46, 204, 113, 0.4);
    }

    .pause {
        background: #f39c12;
        color: white;
    }

    .pause:hover:not(:disabled) {
        background: #e67e22;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(243, 156, 18, 0.4);
    }

    .reset {
        background: #e74c3c;
        color: white;
    }

    .reset:hover:not(:disabled) {
        background: #c0392b;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(231, 76, 60, 0.4);
    }

    @media (max-width: 768px) {
        h1 {
            font-size: 1.8em;
        }

        .time {
            font-size: 40px;
        }

        .container {
            gap: 20px;
        }

        .team {
            width: 100%;
            max-width: 320px;
        }
    }
</style>

</head>

<body>

<h1>🏁 Game Master Stopwatch</h1>

<div class="controls">
    <button class="master-btn start-all" onclick="startAllTimers()" aria-label="Start all timers">
        ▶ Start All
    </button>
    <button class="master-btn pause-all" onclick="pauseAllTimers()" aria-label="Pause all timers">
        ⏸ Pause All
    </button>
    <button class="master-btn reset-all" onclick="resetAllTimers()" aria-label="Reset all timers">
        ⏹ Reset All
    </button>
</div>

<div class="container">

    <div class="team" id="teamA">
        <h2>Team A</h2>
        <div id="timeA" class="time" aria-live="polite">00:00:00</div>

        <div class="button-group">
            <button class="start" onclick="startTimer('A')" aria-label="Start Team A timer">
                ▶ Start
            </button>
            <button class="pause" onclick="pauseTimer('A')" aria-label="Pause Team A timer">
                ⏸ Pause
            </button>
            <button class="reset" onclick="resetTimer('A')" aria-label="Reset Team A timer">
                ⏹ Reset
            </button>
        </div>
    </div>

    <div class="team" id="teamB">
        <h2>Team B</h2>
        <div id="timeB" class="time" aria-live="polite">00:00:00</div>

        <div class="button-group">
            <button class="start" onclick="startTimer('B')" aria-label="Start Team B timer">
                ▶ Start
            </button>
            <button class="pause" onclick="pauseTimer('B')" aria-label="Pause Team B timer">
                ⏸ Pause
            </button>
            <button class="reset" onclick="resetTimer('B')" aria-label="Reset Team B timer">
                ⏹ Reset
            </button>
        </div>
    </div>

</div>


<script>
    // Constants
    const UPDATE_INTERVAL = 10; // milliseconds
    const TEAMS = ['A', 'B'];
    const STORAGE_KEY = 'gameMasterTimers';

    // Timer state
    const timers = {
        A: {
            elapsed: 0,
            startTime: 0,
            running: false
        },
        B: {
            elapsed: 0,
            startTime: 0,
            running: false
        }
    };

    /**
     * Format milliseconds to HH:MM:SS format
     */
    function formatTime(milliseconds) {
        const hours = Math.floor(milliseconds / 3600000);
        const minutes = Math.floor((milliseconds % 3600000) / 60000);
        const seconds = Math.floor((milliseconds % 60000) / 1000);

        return String(hours).padStart(2, '0')
            + ':'
            + String(minutes).padStart(2, '0')
            + ':'
            + String(seconds).padStart(2, '0');
    }

    /**
     * Get current time for a team
     */
    function currentTime(team) {
        if (timers[team].running) {
            return timers[team].elapsed + (performance.now() - timers[team].startTime);
        }
        return timers[team].elapsed;
    }

    /**
     * Update display for a team
     */
    function updateDisplay(team) {
        const timeElement = document.getElementById('time' + team);
        timeElement.textContent = formatTime(currentTime(team));
    }

    /**
     * Update visual state based on timer running status
     */
    function updateVisualState(team) {
        const teamElement = document.getElementById('team' + team);
        if (timers[team].running) {
            teamElement.classList.add('running');
        } else {
            teamElement.classList.remove('running');
        }
    }

    /**
     * Start timer for a team
     */
    function startTimer(team) {
        if (!timers[team].running) {
            timers[team].startTime = performance.now();
            timers[team].running = true;
            updateVisualState(team);
            saveState();
        }
    }

    /**
     * Pause timer for a team
     */
    function pauseTimer(team) {
        if (timers[team].running) {
            timers[team].elapsed = currentTime(team);
            timers[team].running = false;
            updateVisualState(team);
            saveState();
        }
    }

    /**
     * Reset timer for a team
     */
    function resetTimer(team) {
        timers[team].elapsed = 0;
        timers[team].running = false;
        updateDisplay(team);
        updateVisualState(team);
        saveState();
    }

    /**
     * Master controls: Start all timers
     */
    function startAllTimers() {
        TEAMS.forEach(team => startTimer(team));
    }

    /**
     * Master controls: Pause all timers
     */
    function pauseAllTimers() {
        TEAMS.forEach(team => pauseTimer(team));
    }

    /**
     * Master controls: Reset all timers
     */
    function resetAllTimers() {
        if (confirm('Are you sure you want to reset all timers?')) {
            TEAMS.forEach(team => resetTimer(team));
        }
    }

    /**
     * Save timer state to localStorage
     */
    function saveState() {
        const state = {};
        TEAMS.forEach(team => {
            state[team] = {
                elapsed: timers[team].elapsed,
                running: timers[team].running,
                startTime: timers[team].startTime
            };
        });
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    }

    /**
     * Load timer state from localStorage
     */
    function loadState() {
        const saved = localStorage.getItem(STORAGE_KEY);
        if (saved) {
            try {
                const state = JSON.parse(saved);
                TEAMS.forEach(team => {
                    if (state[team]) {
                        timers[team].elapsed = state[team].elapsed;
                        // Don't auto-resume; just restore the elapsed time
                        timers[team].running = false;
                        updateDisplay(team);
                    }
                });
            } catch (e) {
                console.error('Failed to load saved timer state:', e);
            }
        }
    }

    // Initialize
    loadState();

    // Update display smoothly
    setInterval(() => {
        TEAMS.forEach(team => updateDisplay(team));
    }, UPDATE_INTERVAL);

</script>

</body>

</html>
